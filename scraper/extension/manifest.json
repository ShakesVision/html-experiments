{
  "manifest_version": 3,
  "name": "Scrape — Web Data Extractor",
  "version": "0.1.0",
  "description": "Scrape any web page — including JavaScript sites — with a point-and-click picker. Built-in CORS bypass, no external proxy.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrape this page"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "optional_host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["https://tools.shakeeb.in/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["engine/*.js", "picker.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
